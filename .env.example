# Agnivo backend environment template. Copy to .env for local development.
# All platform variables are prefixed with AGNIVO_ and use _ for nesting.

# --- App ---
AGNIVO_APP_ENVIRONMENT=development
AGNIVO_CONFIG_DIR=configs

# --- Logging ---
AGNIVO_LOG_LEVEL=debug
AGNIVO_LOG_FORMAT=console

# --- HTTP (enable for the api executable; workers leave disabled) ---
AGNIVO_HTTP_ENABLED=true
AGNIVO_HTTP_PORT=8080

# --- Admin server (health + metrics), per executable ---
AGNIVO_OBSERVABILITY_ADMIN_PORT=9090

# --- Security (required in production) ---
# AGNIVO_SECURITY_INTERNAL_SERVICE_TOKEN=   # 64+ byte random; protects internal APIs
# AGNIVO_SECURITY_METRICS_BEARER_TOKEN=     # optional; protects /metrics
# AGNIVO_SECURITY_MAX_REQUEST_BODY_BYTES=10485760
# AGNIVO_SECURITY_ENABLE_HSTS=true

# --- Database (pgx) ---
AGNIVO_DATABASE_ENABLED=false
AGNIVO_DATABASE_URL=postgres://agnivo:agnivo@localhost:5432/agnivo?sslmode=disable

# --- Redis ---
AGNIVO_REDIS_ENABLED=false
AGNIVO_REDIS_URL=redis://localhost:6379/0

# --- Tracing (OpenTelemetry) ---
AGNIVO_OBSERVABILITY_TRACING_ENABLED=false
AGNIVO_OBSERVABILITY_TRACING_EXPORTER=otlp
AGNIVO_OBSERVABILITY_TRACING_ENDPOINT=localhost:4318
AGNIVO_OBSERVABILITY_TRACING_INSECURE=true

# --- Identity & Access (JWT RS256) ---
# Leave PEM keys empty in development to auto-generate ephemeral keys at startup.
# AGNIVO_IDENTITY_JWT_PRIVATE_KEY_PEM=
# AGNIVO_IDENTITY_JWT_PUBLIC_KEY_PEM=
AGNIVO_IDENTITY_JWT_ISSUER=agnivo
AGNIVO_IDENTITY_JWT_AUDIENCE=agnivo-api
AGNIVO_IDENTITY_JWT_ACCESS_TTL=15m
AGNIVO_IDENTITY_JWT_REFRESH_TTL=720h
# --- Control Plane ---
# AGNIVO_CONTROLPLANE_ENCRYPTION_KEY=  # 32-byte key, base64 or hex; auto-dev if empty
AGNIVO_CONTROLPLANE_DEFAULT_REGION=us-east-1
# AGNIVO_CONTROLPLANE_WEBHOOKS_GITHUB_SECRET=
# AGNIVO_CONTROLPLANE_WEBHOOKS_GITLAB_SECRET=
# --- Builder ---
AGNIVO_BUILDER_CONCURRENCY=4
AGNIVO_BUILDER_WORKSPACE_DIR=/tmp/agnivo-builds
AGNIVO_BUILDER_VISIBILITY=30m
AGNIVO_BUILDER_POLL_INTERVAL=1s
AGNIVO_BUILDER_DOCKER_CLI=docker
AGNIVO_BUILDER_INTERNAL_PORT=8082
AGNIVO_BUILDER_ECR_ENABLED=false
AGNIVO_BUILDER_ECR_REGION=us-east-1
# AGNIVO_BUILDER_ECR_REGISTRY=123456789012.dkr.ecr.us-east-1.amazonaws.com
AGNIVO_BUILDER_CACHE_ENABLED=true
AGNIVO_BUILDER_CACHE_INLINE_CACHE=true
# --- Deployer ---
AGNIVO_DEPLOYER_CONCURRENCY=8
AGNIVO_DEPLOYER_VISIBILITY=20m
AGNIVO_DEPLOYER_POLL_INTERVAL=1s
AGNIVO_DEPLOYER_DOCKER_CLI=docker
AGNIVO_DEPLOYER_INTERNAL_PORT=8083
AGNIVO_DEPLOYER_DEFAULT_STRATEGY=rolling
AGNIVO_DEPLOYER_ECR_ENABLED=false
AGNIVO_DEPLOYER_ECR_REGION=us-east-1
# AGNIVO_DEPLOYER_SCHEDULER_URL=http://scheduler:8084
# AGNIVO_DEPLOYER_RUNTIME_AGENT_URL=http://runtime-agent:8085
AGNIVO_DEPLOYER_HEALTH_STARTUP_TIMEOUT=5m
AGNIVO_DEPLOYER_HEALTH_HTTP_PATH=/health
AGNIVO_DEPLOYER_NETWORK_DOCKER_NETWORK=agnivo
AGNIVO_DEPLOYER_NETWORK_HOST_PORT_MIN=30000
AGNIVO_DEPLOYER_NETWORK_HOST_PORT_MAX=40000
# --- Scheduler ---
AGNIVO_SCHEDULER_INTERNAL_PORT=8084
AGNIVO_SCHEDULER_DEFAULT_ALGORITHM=least_loaded
AGNIVO_SCHEDULER_RESERVATION_TTL=30m
AGNIVO_SCHEDULER_HEARTBEAT_INTERVAL=15s
AGNIVO_SCHEDULER_MISSED_HEARTBEATS=3
AGNIVO_SCHEDULER_OVERCOMMIT_RATIO=1.0
AGNIVO_SCHEDULER_RECONCILE_INTERVAL=30s
# --- Runtime Agent ---
AGNIVO_RUNTIME_AGENT_INTERNAL_PORT=8085
AGNIVO_RUNTIME_AGENT_SCHEDULER_URL=http://127.0.0.1:8084
AGNIVO_RUNTIME_AGENT_ADVERTISE_HOST=127.0.0.1
AGNIVO_RUNTIME_AGENT_ADVERTISE_PORT=8085
AGNIVO_RUNTIME_AGENT_REGION=us-east-1
AGNIVO_RUNTIME_AGENT_HEARTBEAT_INTERVAL=15s
AGNIVO_RUNTIME_AGENT_HEALTH_INTERVAL=10s
AGNIVO_RUNTIME_AGENT_GC_INTERVAL=5m
AGNIVO_RUNTIME_AGENT_DOCKER_NETWORK=agnivo
AGNIVO_RUNTIME_AGENT_MAX_CONTAINERS=200
AGNIVO_RUNTIME_AGENT_CPU_CORES=4
AGNIVO_RUNTIME_AGENT_MEMORY_MB=8192
AGNIVO_RUNTIME_AGENT_DISK_GB=100
# Point deployer at scheduler + runtime agent when running full stack:
# AGNIVO_DEPLOYER_SCHEDULER_URL=http://127.0.0.1:8084
# AGNIVO_DEPLOYER_RUNTIME_AGENT_URL=http://127.0.0.1:8085
